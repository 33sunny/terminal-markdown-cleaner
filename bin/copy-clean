#!/bin/zsh
set -euo pipefail

SCRIPT_PATH="${0:A}"
PROJECT_ROOT="${SCRIPT_PATH:h:h}"
HAMMERSPOON_CONFIG="$PROJECT_ROOT/hammerspoon/init.lua"
TARGET_CONFIG="$HOME/.hammerspoon/init.lua"
ROOT_FILE="$HOME/.hammerspoon/terminal-markdown-cleaner-root"

mkdir -p "$HOME/.hammerspoon"
print -r -- "$PROJECT_ROOT" >"$ROOT_FILE"

if [[ -e "$TARGET_CONFIG" && ! -L "$TARGET_CONFIG" ]]; then
  echo "copy-clean stopped: $TARGET_CONFIG exists and is not a symlink."
  echo "Add this line to that file instead:"
  echo "dofile(\"$HAMMERSPOON_CONFIG\")"
  exit 1
fi

if [[ ! -e "$TARGET_CONFIG" || "$(readlink "$TARGET_CONFIG" 2>/dev/null || true)" != "$HAMMERSPOON_CONFIG" ]]; then
  ln -sfn "$HAMMERSPOON_CONFIG" "$TARGET_CONFIG"
fi

if [[ "$(osascript -e 'application "Hammerspoon" is running')" == "true" ]]; then
  osascript -e 'tell application "Hammerspoon" to quit'
  sleep 0.4
fi

open -a Hammerspoon
sleep 0.8

echo "copy-clean is running. Ghostty Command+C cleanup is active after Hammerspoon loads."
